{
  "name": "adapter-bun",
  "version": "0.0.1",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "private": true,
  "scripts": {
    "clean": "rm -rf ./dist",
    "build:src": "bunx tsc -p ./tsconfig.build.json",
    "build": "bun run clean && bun run build:src",
    "prepare": "bun run build",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@next/routing": "16.2.0-canary.35",
    "edge-runtime": "^4.0.1",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "next": "^16.2.0-canary.35"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}

{
  "name": "adapter-bun",
  "version": "0.0.2",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "clean": "rm -rf ./dist",
    "build:src": "tsc -p ./tsconfig.build.json",
    "build": "npm run clean && npm run build:src",
    "prepare": "npm run build:src",
    "test": "npm test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "next": "16.2.4",
    "typescript": "^5"
  }
}
